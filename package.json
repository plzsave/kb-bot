{
  "name": "kb-bot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Slack/Discord ナレッジ Bot。R2/S3 の md と GitHub 実コードを根拠に、低コストで仕様・使い方を解説する。",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "start:discord": "bun run src/discord.ts",
    "dev:discord": "bun --watch run src/discord.ts",
    "kb:ingest": "bun run scripts/kb-ingest.ts",
    "kb:search": "bun run scripts/kb-search.ts",
    "kb:issues": "bun run scripts/issue-to-kb.ts",
    "kb:prune": "bun run scripts/kb-prune.ts",
    "kb:eval": "bun run scripts/kb-eval.ts",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "bun test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "@google/genai": "^2.11.0",
    "@slack/bolt": "^4.7.3",
    "aws4fetch": "^1.0.20",
    "discord.js": "^14.26.4",
    "openai": "^6.46.0",
    "tiny-segmenter": "^0.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/bun": "^1.3.14",
    "typescript": "^7.0.2"
  }
}
