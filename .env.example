# --- ナレッジソース（R2 / S3 / GCS いずれも S3 互換で同一設定）---
# 例(R2): https://<acct>.r2.cloudflarestorage.com
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# バケット内のどの接頭辞配下の .md を取り込むか（空=全体）
S3_PREFIX=

# --- ローカル SQLite（FTS5 インデックス＋回答キャッシュ）---
# R2 から導出する派生物。消えても再取り込みで再構築できる。
KB_DB_PATH=./kb.sqlite
# 回答キャッシュの有効期限（時間）。ドキュメント/コード更新で陳腐化するため既定24h。0で無期限。
# キャッシュキーには provider:model も含まれるので、KB_LLM_PROVIDER / KB_MODEL を切り替えると
# 旧モデルの回答は自動的に miss になり、新モデルで再生成される（旧回答の配信は起きない）。
KB_CACHE_TTL_HOURS=24

# --- プラットフォーム選択（コンテナ起動時）---
# slack（既定）/ discord。`bun run start` / `start:discord` を直接使う場合は不要。
KB_PLATFORM=slack

# --- Slack（Socket Mode・KB_PLATFORM=slack のとき）---
# Bot Token: xoxb-...（OAuth & Permissions）
SLACK_BOT_TOKEN=
# App-Level Token: xapp-...（Basic Information → App-Level Tokens, scope: connections:write）
SLACK_APP_TOKEN=

# --- Discord（KB_PLATFORM=discord のとき）---
# Bot Token（Developer Portal → Bot）。MESSAGE CONTENT INTENT を有効化すること。
DISCORD_BOT_TOKEN=

# --- GitHub コード参照（任意・「実コードで仕様を語る」機能）---
# 参照を許可するリポジトリ（owner/name のカンマ区切り）。未設定ならこの機能はオフ。
# 例: KB_GITHUB_REPOS=plzsave/kb-bot,plzsave/mdcollab
KB_GITHUB_REPOS=
# Personal Access Token（private リポや code search に必要。public の tree/read のみなら無くても可だが推奨）。
# 最小権限: Contents read-only（fine-grained PAT を対象リポに限定するのが安全）。
# 注: 下の GitHub App 認証（推奨）が揃っていればそちらが優先され、この値は使われない。
GITHUB_TOKEN=

# --- GitHub App 認証（推奨・GITHUB_TOKEN の代替）---
# 3つすべて設定すると PAT の代わりに App の installation token（約1h・自動更新）を使う。
# PAT と違い期限切れローテーションが不要になる。App の作成手順は README の GitHub 節を参照。
GITHUB_APP_ID=
# 秘密鍵 PEM ファイルのパス（推奨。compose なら read-only mount する。env 直書きは改行で壊れるため不可）
GITHUB_APP_PRIVATE_KEY_PATH=
# インストール先 ID（https://github.com/settings/installations/<この数値>）
GITHUB_APP_INSTALLATION_ID=

# --- 追加システムプロンプト（任意・コードを書き換えずに口調/方針を微調整）---
# 内蔵のベースプロンプト（役割・安全・出力スタイル・自動言語判別）はコード側に残したまま、
# ここで与えた指示を末尾に追記する。例:「もう少し噛み砕いて、専門用語は避けて」。
# 反映方法は環境で選べる:
#  (1) R2/S3 のオブジェクト（既定）: 下記キーに .md を置くと実行時に取得。バケットを書き換えるだけで
#      再ビルド/再デプロイ不要、最長 TTL 後に再起動なしで反映（fly.io/ECS 等に最適）。
#  (2) インライン: KB_SYSTEM_PROMPT_EXTRA に直接書くと S3 を見ず最優先（ローカル検証向け）。
# 追加指示のオブジェクトキー（ナレッジと混ざらないよう _config/ 配下。ingest 対象から除外される）。
KB_SYSTEM_PROMPT_KEY=_config/system-prompt.md
# バケット取得のキャッシュ秒数（既定60）。小さいほど反映が速いが取得頻度が上がる。0で毎回取得。
KB_SYSTEM_PROMPT_TTL_SEC=60
# インライン追加指示（設定時は S3 を見ず最優先）。複数行は扱いづらいので簡易検証向け。
KB_SYSTEM_PROMPT_EXTRA=

# --- Issue ナレッジ化バッチ（任意・scripts/issue-to-kb.ts）---
# closed issue を収集する対象リポジトリ（KB_GITHUB_REPOS とは分離）。--repos で上書き可。
KB_ISSUE_REPOS=
# この件数未満のコメントの issue は除外（既定1）。
KB_ISSUE_MIN_COMMENTS=1
# 増分取得カーソル（issue ごとの updated_at）の保存先。これが消えると次回は全件を再要約する
# ＝LLM 課金が無駄に増えるので、永続化先に置くこと。既定 ./data/... はイメージの WORKDIR(/app)
# 上で /app/data に解決＝compose の kbdata ボリュームに乗る。kb:issues を別コンテナ/cron で回す
# 場合は、同じ kbdata ボリュームを /app/data にマウントして /app から実行すること。
KB_ISSUE_STATE_FILE=./data/issue-kb-state.json

# --- LLM プロバイダ選択 ---
# anthropic（既定）/ gemini / openai。選んだプロバイダの API キーだけが必須。
# 回答キャッシュ・FTS 検索は LLM 非依存で常に効く。プロンプトキャッシュも各社方式で割引維持。
KB_LLM_PROVIDER=anthropic
# 基本（最安）ティア。空ならプロバイダ別の既定
#（anthropic=claude-haiku-4-5 / gemini=gemini-3.1-flash-lite / openai=gpt-5.4-nano）。
KB_MODEL=
# 難問昇格先（上位ティア）。設定すると「難問だけ自動で上位モデルへ」が有効になる。
# A: FTS 空振りのコード質問は最初から上位 / B: 最安が打ち切られたら上位で再実行。
# 空なら昇格は無効（常に基本ティア）。例 anthropic→claude-sonnet-4-6 / gemini→gemini-3.5-flash / openai→gpt-5.4-mini。
KB_MODEL_HARD=

# --- Anthropic（KB_LLM_PROVIDER=anthropic のとき必須）---
ANTHROPIC_API_KEY=

# --- Gemini（KB_LLM_PROVIDER=gemini のとき必須）---
GEMINI_API_KEY=

# --- OpenAI（KB_LLM_PROVIDER=openai のとき必須）---
OPENAI_API_KEY=

# --- eval 集約ゲート（kb:eval） ---
# 合格率が「基準（eval/baseline.json）− band」を下回ったら exit 1（全体劣化の検知）。
# band 既定 0.10 はライブ 2 run の実測 flip 率から較正済み。基準の再記録は --update-baseline。
# KB_EVAL_BAND=0.10
# KB_EVAL_MIN_N=30
