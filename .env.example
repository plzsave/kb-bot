# --- ナレッジソース（R2 / S3 / GCS いずれも S3 互換で同一設定）---
# 例(R2): https://<acct>.r2.cloudflarestorage.com
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# バケット内のどの接頭辞配下の .md を取り込むか（空=全体）
S3_PREFIX=

# --- ローカル SQLite（FTS5 インデックス＋回答キャッシュ）---
# R2 から導出する派生物。消えても再取り込みで再構築できる。
KB_DB_PATH=./kb.sqlite
# 回答キャッシュの有効期限（時間）。ドキュメント/コード更新で陳腐化するため既定24h。0で無期限。
KB_CACHE_TTL_HOURS=24

# --- プラットフォーム選択（コンテナ起動時）---
# slack（既定）/ discord。`bun run start` / `start:discord` を直接使う場合は不要。
KB_PLATFORM=slack

# --- Slack（Socket Mode・KB_PLATFORM=slack のとき）---
# Bot Token: xoxb-...（OAuth & Permissions）
SLACK_BOT_TOKEN=
# App-Level Token: xapp-...（Basic Information → App-Level Tokens, scope: connections:write）
SLACK_APP_TOKEN=

# --- Discord（KB_PLATFORM=discord のとき）---
# Bot Token（Developer Portal → Bot）。MESSAGE CONTENT INTENT を有効化すること。
DISCORD_BOT_TOKEN=

# --- GitHub コード参照（任意・「実コードで仕様を語る」機能）---
# 参照を許可するリポジトリ（owner/name のカンマ区切り）。未設定ならこの機能はオフ。
# 例: KB_GITHUB_REPOS=plzsave/kb-bot,plzsave/mdcollab
KB_GITHUB_REPOS=
# Personal Access Token（private リポや code search に必要。public の tree/read のみなら無くても可だが推奨）。
# 最小権限: Contents read-only（fine-grained PAT を対象リポに限定するのが安全）。
GITHUB_TOKEN=

# --- Issue ナレッジ化バッチ（任意・scripts/issue-to-kb.ts）---
# closed issue を収集する対象リポジトリ（KB_GITHUB_REPOS とは分離）。--repos で上書き可。
KB_ISSUE_REPOS=
# この件数未満のコメントの issue は除外（既定1）。
KB_ISSUE_MIN_COMMENTS=1
# 増分取得カーソル等の保存先（Docker volume 配下推奨）。
KB_ISSUE_STATE_FILE=./data/issue-kb-state.json

# --- LLM プロバイダ選択 ---
# anthropic（既定）/ gemini / openai。選んだプロバイダの API キーだけが必須。
# 回答キャッシュ・FTS 検索は LLM 非依存で常に効く。プロンプトキャッシュも各社方式で割引維持。
KB_LLM_PROVIDER=anthropic
# 既定モデルはプロバイダ別の最安ティア
#（anthropic=claude-haiku-4-5 / gemini=gemini-3.1-flash-lite / openai=gpt-5.4-nano）。
# 難問だけ上位へ：例 anthropic→claude-sonnet-4-6 / gemini→gemini-3.5-flash / openai→gpt-5.4-mini。
# 空なら既定を使う。
KB_MODEL=

# --- Anthropic（KB_LLM_PROVIDER=anthropic のとき必須）---
ANTHROPIC_API_KEY=

# --- Gemini（KB_LLM_PROVIDER=gemini のとき必須）---
GEMINI_API_KEY=

# --- OpenAI（KB_LLM_PROVIDER=openai のとき必須）---
OPENAI_API_KEY=
